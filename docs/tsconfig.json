{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "allowJs": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "types": ["vite/client", "vitepress/client"]
  },
  "include": [
    "**/*.ts",
    "**/*.vue",
    "**/*.md",
    ".vitepress/**/*.ts",
    ".vitepress/**/*.vue"
  ]
}
