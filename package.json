{
  "name": "quality-meter-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "docs",
    "library"
  ],
  "scripts": {
    "dev": "vitepress dev docs",
    "build": "vitepress build docs",
    "build:library": "tsup --config library/tsup.config.ts",
    "preview": "vitepress preview docs",
    "benchmark": "bun tools/scripts/run-benchmark.ts",
    "benchmark:adaptive": "bun tools/scripts/run-adaptive-refinement-benchmark.ts",
    "benchmark:hard-negative": "bun tools/scripts/run-hard-negative-benchmark.ts",
    "benchmark:low-latency": "bun tools/scripts/run-low-latency-iterations.ts",
    "benchmark:model-bakeoff": "bun tools/scripts/run-model-bakeoff.ts",
    "benchmark:wording": "bun tools/scripts/run-wording-experiments.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "package:library": "bun tools/scripts/create-package-release.ts"
  },
  "dependencies": {
    "@browser-quality-scorer/core": "workspace:*",
    "@huggingface/transformers": "^4.0.1"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitepress": "^2.0.0-alpha.17"
  }
