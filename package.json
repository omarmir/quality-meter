{
  "name": "quality-meter-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "docs",
    "library"
  ],
  "scripts": {
    "dev": "vitepress dev docs",
    "build": "vitepress build docs",
    "build:library": "tsup --config library/tsup.config.ts",
    "preview": "vitepress preview docs",
    "report:main": "bun tools/scripts/run-report.ts main",
    "report:hard-negative": "bun tools/scripts/run-report.ts hard-negative",
    "report:adaptive": "bun tools/scripts/run-report.ts adaptive",
    "report:scoring-improvement": "bun tools/scripts/run-report.ts scoring-improvement",
    "report:low-latency": "bun tools/scripts/run-report.ts low-latency",
    "report:wording-exp": "bun tools/scripts/run-report.ts wording-exp",
    "report:model-bakeoff": "bun tools/scripts/run-report.ts model-bakeoff",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "package:library": "bun tools/scripts/create-package-release.ts"
  },
  "dependencies": {
    "@browser-quality-scorer/core": "workspace:*",
    "@huggingface/transformers": "^4.0.1"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitepress": "^2.0.0-alpha.17"
  }
}
